{
  "name": "@ffmpeg-rest/server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "esbuild src/server.ts --bundle --sourcemap --platform=node --format=esm --packages=external --loader:.node=file --outfile=dist/server.js",
    "start": "node ./dist/server.js",
    "typecheck": "tsc --noEmit",
    "test:app": "TEST_MODE=app vitest --config vitest.config.ts --exclude '**/integration.test.ts'",
    "test:integration": "TEST_MODE=integration vitest --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:coverage": "vitest --config vitest.config.ts --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.901.0",
    "@hono/node-server": "^1.19.5",
    "@hono/zod-openapi": "^1.1.3",
    "@scalar/hono-api-reference": "^0.9.20",
    "@scalar/openapi-to-markdown": "^0.2.43",
    "bullmq": "^5.60.0",
    "cacache": "^20.0.3",
    "dotenv": "^17.2.3",
    "hono": "^4.9.9",
    "ioredis": "^5.8.0",
    "pino": "^10.0.0",
    "pino-pretty": "^13.1.1",
    "safe-stable-stringify": "^2.5.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/cacache": "^20.0.1"
  }
}
